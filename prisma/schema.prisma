generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EditJobStatus {
  queued
  processing
  succeeded
  failed
}

model EditJob {
  id              String          @id @default(cuid())
  status          EditJobStatus   @default(queued)
  stage           String?
  progress        Int?
  prompt          String?
  sourceImageUrl  String
  maskImageUrl    String
  resultImageUrl  String?
  sourceMimeType  String?
  resultMimeType  String?
  width           Int?
  height          Int?
  fileSize        Int?
  provider        String          @default("openrouter")
  model           String          @default("openai/gpt-5-image-mini")
  errorCode       String?
  errorMessage    String?
  processingMs    Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  startedAt       DateTime?
  finishedAt      DateTime?
  events          EditJobEvent[]
}

model EditJobEvent {
  id          String   @id @default(cuid())
  jobId       String
  type        String
  message     String?
  payloadJson Json?
  createdAt   DateTime @default(now())

  job EditJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}
