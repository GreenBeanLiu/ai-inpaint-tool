# ─── Minimal env for local UI-only development ───────────────────────────────
# Only DATABASE_URL is needed to browse the job list and detail pages.
# All other vars are required for the full upload → worker → result pipeline.

# Required for database-backed job creation and reads.
DATABASE_URL="postgresql://user:password@host:5432/database"

# Used when generating absolute URLs in future integrations.
APP_BASE_URL="http://localhost:3000"

# ─── Storage (required for upload/result pipeline) ────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# ─── Trigger.dev (required for background job dispatch and worker startup) ────
TRIGGER_SECRET_KEY=""
TRIGGER_API_URL="https://api.trigger.dev"
TRIGGER_PROJECT_REF=""

# ─── Providers ────────────────────────────────────────────────────────────────
# Default masked image editing provider via the Tikhub OpenAI-compatible gateway.
# Required for the default inpainting path.
TIKHUB_API_KEY=""
TIKHUB_API_BASE_URL="https://ai.tikhub.io/v1"
TIKHUB_IMAGE_EDIT_PATH="/images/edits"
TIKHUB_IMAGE_MODEL="gpt-image-2"

# Optional direct OpenAI provider slot.
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1"

# Optional alternate provider slot.
OPENROUTER_API_KEY=""
OPENROUTER_IMAGE_MODEL="openai/gpt-5-image-mini"

# Optional alternate provider slot. Explicit binary-mask inpainting is not
# currently supported on the documented Gemini API-key flow, so masked Gemini
# submissions fail explicitly.
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_IMAGE_MODEL="gemini-3.1-flash-image"

# Reserved for future realtime delivery wiring.
JOB_EVENTS_WS_URL=""
