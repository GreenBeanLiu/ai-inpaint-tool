# Required for database-backed job creation and reads.
# Local Prisma development can use a file path, but the current verified backend uses Postgres.
DATABASE_URL="postgresql://user:password@host:5432/database"

# Used when generating absolute URLs in future integrations.
APP_BASE_URL="http://localhost:3000"

# Required for real source/mask upload and result storage in Cloudflare R2.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# Required for Gemini image editing attempts. Exact mask-based inpainting is not currently supported by
# the documented Gemini API-key image editing flow, so masked jobs fail honestly in the worker.
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_IMAGE_MODEL="gemini-3.1-flash-image"

# Required for Trigger.dev dispatch and worker registration.
TRIGGER_SECRET_KEY=""
TRIGGER_API_URL="https://api.trigger.dev"
TRIGGER_PROJECT_REF=""

# Reserved for future realtime delivery wiring.
JOB_EVENTS_WS_URL=""
