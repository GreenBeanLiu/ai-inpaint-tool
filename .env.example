# Required for the local closed loop in this scaffold.
# Relative SQLite paths are resolved from prisma/schema.prisma, so this creates prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Used when generating absolute URLs in future integrations.
APP_BASE_URL="http://localhost:3000"

# Required only when Cloudflare R2 upload/download wiring is implemented.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# Required only when Gemini image editing wiring is implemented.
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_IMAGE_MODEL="gemini-3.1-flash-image"

# Reserved for future background execution and realtime delivery wiring.
TRIGGER_SECRET_KEY=""
TRIGGER_API_URL=""
JOB_EVENTS_WS_URL=""
